generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // "user" | "admin"
  balance       Int       @default(0) // số dư điểm (cache = tổng ledger); BXH xếp theo field này
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  picks         Pick[]
  txns          WalletTransaction[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Giải đấu (M1) ----------

enum Stage {
  GROUP
  R32
  R16
  QF
  SF
  THIRD
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
}

model Group {
  id    String @id @default(cuid())
  name  String @unique // "A".."L"
  teams Team[]
}

model Team {
  id          String   @id @default(cuid())
  name        String // "Brazil", "Việt Nam"
  code        String   @unique // FIFA code: "BRA", "VIE"
  flag        String? // emoji cờ hoặc URL
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id])
  createdAt   DateTime @default(now())
  homeMatches Match[]  @relation("home")
  awayMatches Match[]  @relation("away")
}

model Match {
  id          String      @id @default(cuid())
  stage       Stage
  groupName   String? // hiển thị vòng bảng "A".."L"
  matchday    Int? // lượt vòng bảng 1..3
  bracketSlot String? // vị trí trong nhánh knock-out: "R32-1".."FINAL"
  kickoff     DateTime
  status      MatchStatus @default(SCHEDULED)
  homeTeamId  String?
  awayTeamId  String?
  homeTeam    Team?       @relation("home", fields: [homeTeamId], references: [id])
  awayTeam    Team?       @relation("away", fields: [awayTeamId], references: [id])
  homeScore   Int?
  awayScore   Int?
  homePens    Int? // loạt luân lưu (knock-out)
  awayPens    Int?
  venue       String?
  preview     String? // thông tin/nhận định trước trận
  externalId  String?     @unique // id từ football-data API để sync
  stats       MatchStats?
  picks       Pick[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([stage, kickoff])
  @@index([kickoff])
}

model MatchStats {
  id          String @id @default(cuid())
  matchId     String @unique
  match       Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homeCorners Int?
  awayCorners Int?
  homeYellow  Int?
  awayYellow  Int?
  homeRed     Int?
  awayRed     Int?
  homeShots   Int?
  awayShots   Int?
  homePoss    Int? // % kiểm soát bóng
  awayPoss    Int?
}

// ---------- Pickems & Ví / sổ cái (M2) ----------

enum PickChoice {
  HOME
  DRAW
  AWAY
}

enum PickStatus {
  PENDING
  WON
  LOST
}

enum TxType {
  WELCOME // thưởng đăng ký
  PICKEM_WIN // pickems đoán đúng
  DRIP // điểm hằng ngày
  BET_STAKE // đặt cược (trừ)
  BET_WIN // thắng cược (cộng)
  LOAN // vay
  REPAY // trả nợ + lãi
  SHARE // nạp qua share MXH
  AD // nạp qua xem quảng cáo
  ADJUST // admin chỉnh tay
}

model Pick {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId   String
  match     Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  choice    PickChoice
  status    PickStatus @default(PENDING)
  points    Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId, matchId])
  @@index([matchId])
}

model WalletTransaction {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         TxType
  amount       Int // +/- điểm
  balanceAfter Int // số dư SAU giao dịch (minh bạch)
  refType      String? // "match" | "bet" | "loan" ...
  refId        String?
  note         String?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}
