generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (Neon) cho app runtime
  directUrl = env("DIRECT_URL") // direct cho prisma migrate (Neon pooling không chạy migrate được)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // "user" | "admin"
  balance       Int       @default(0) // số dư điểm (cache = tổng ledger); BXH xếp theo field này
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  picks         Pick[]
  txns          WalletTransaction[]
  bets          Bet[]
  loans         Loan[]
  referralCode  String?   @unique // link mời bạn bè
  referredById  String? // ai đã mời user này
  referredBy    User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals     User[]    @relation("Referrals")
  ownedLeagues  League[]       @relation("LeagueOwner")
  leagueMembers LeagueMember[]
  championBet   ChampionBet?
  checkinStreak Int            @default(0) // chuỗi check-in liên tiếp
  lastCheckinAt DateTime?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Giải đấu (M1) ----------

enum Stage {
  GROUP
  R32
  R16
  QF
  SF
  THIRD
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
}

model Group {
  id    String @id @default(cuid())
  name  String @unique // "A".."L"
  teams Team[]
}

model Team {
  id          String   @id @default(cuid())
  name        String // "Brazil", "Việt Nam"
  code        String   @unique // FIFA code: "BRA", "VIE"
  flag        String? // emoji cờ hoặc URL
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id])
  createdAt   DateTime @default(now())
  homeMatches Match[]  @relation("home")
  awayMatches Match[]  @relation("away")
  championBets ChampionBet[]
}

model Match {
  id          String      @id @default(cuid())
  stage       Stage
  groupName   String? // hiển thị vòng bảng "A".."L"
  matchday    Int? // lượt vòng bảng 1..3
  bracketSlot String? // vị trí trong nhánh knock-out: "R32-1".."FINAL"
  kickoff     DateTime
  status      MatchStatus @default(SCHEDULED)
  homeTeamId  String?
  awayTeamId  String?
  homeTeam    Team?       @relation("home", fields: [homeTeamId], references: [id])
  awayTeam    Team?       @relation("away", fields: [awayTeamId], references: [id])
  homeScore   Int?
  awayScore   Int?
  homePens    Int? // loạt luân lưu (knock-out)
  awayPens    Int?
  venue       String?
  preview     String? // thông tin/nhận định trước trận
  homeLineup  String? // đội hình ra sân (text, nhập qua admin ingest)
  awayLineup  String?
  externalId  String?     @unique // id từ football-data API để sync
  stats       MatchStats?
  picks       Pick[]
  markets     Market[]
  posts       Post[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([stage, kickoff])
  @@index([kickoff])
}

model MatchStats {
  id          String @id @default(cuid())
  matchId     String @unique
  match       Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homeCorners Int?
  awayCorners Int?
  homeYellow  Int?
  awayYellow  Int?
  homeRed     Int?
  awayRed     Int?
  homeShots   Int?
  awayShots   Int?
  homePoss    Int? // % kiểm soát bóng
  awayPoss    Int?
}

// ---------- Pickems & Ví / sổ cái (M2) ----------

enum PickChoice {
  HOME
  DRAW
  AWAY
}

enum PickStatus {
  PENDING
  WON
  LOST
}

enum TxType {
  WELCOME // thưởng đăng ký
  PICKEM_WIN // pickems đoán đúng
  DRIP // điểm hằng ngày
  BET_STAKE // đặt cược (trừ)
  BET_WIN // thắng cược (cộng)
  LOAN // vay
  REPAY // trả nợ + lãi
  SHARE // (cũ) nạp qua share MXH — đã thay bằng referral
  AD // (tạm tắt) nạp qua xem quảng cáo
  REFERRAL // thưởng khi mời được bạn mới
  REFERRED // thưởng cho người mới đăng ký qua link
  ADJUST // admin chỉnh tay
}

model Pick {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId   String
  match     Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  choice    PickChoice
  status    PickStatus @default(PENDING)
  points    Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId, matchId])
  @@index([matchId])
}

model WalletTransaction {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         TxType
  amount       Int // +/- điểm
  balanceAfter Int // số dư SAU giao dịch (minh bạch)
  refType      String? // "match" | "bet" | "loan" ...
  refId        String?
  note         String?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

// ---------- Kèo cá cược (M3) ----------

enum MarketType {
  MATCH_1X2 // 1x2 (thắng/hòa/thua)
  GOALS_OU // tài xỉu bàn thắng
  CORNERS_OU // phạt góc tài/xỉu
  CARDS_OU // thẻ tài/xỉu
}

enum MarketMode {
  FIXED // tỉ lệ cố định (AI/admin set)
  PARIMUTUEL // chia pool theo lượng cược
}

enum MarketStatus {
  OPEN
  LOCKED
  SETTLED
  VOID
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOID
}

model Market {
  id         String            @id @default(cuid())
  matchId    String
  match      Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type       MarketType
  line       Float? // ngưỡng tài/xỉu (vd 2.5)
  mode       MarketMode        @default(FIXED)
  status     MarketStatus      @default(OPEN)
  result     String? // selection key thắng (sau settle)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  selections MarketSelection[]
  bets       Bet[]

  @@index([matchId])
}

model MarketSelection {
  id       String @id @default(cuid())
  marketId String
  market   Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
  key      String // "HOME"|"DRAW"|"AWAY"|"OVER"|"UNDER"
  label    String
  odds     Float  @default(2.0) // tỉ lệ FIXED

  @@unique([marketId, key])
}

model Bet {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketId     String
  market       Market    @relation(fields: [marketId], references: [id], onDelete: Cascade)
  selectionKey String
  stake        Int
  oddsAtBet    Float?
  payout       Int?
  status       BetStatus @default(PENDING)
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([marketId])
}

// ---------- Vay điểm (M4) ----------

enum LoanStatus {
  ACTIVE
  REPAID
}

model Loan {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  principal   Int // số vay gốc
  interestPct Int        @default(10)
  outstanding Int // còn phải trả (gốc + lãi - đã trả)
  status      LoanStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId, status])
}

// ---------- Tin tức / CMS (M5) ----------

enum PostType {
  PREVIEW // trước trận
  RECAP // sau trận
  ANALYSIS // nhận định
  TIP // soi kèo
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum AuthorType {
  AI
  ADMIN
}

model Post {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  body        String // markdown
  type        PostType   @default(ANALYSIS)
  status      PostStatus @default(DRAFT)
  authorType  AuthorType @default(AI)
  matchId     String?
  match       Match?     @relation(fields: [matchId], references: [id], onDelete: SetNull)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
}

// ---------- League / nhóm đua riêng ----------

model League {
  id        String         @id @default(cuid())
  name      String
  code      String         @unique // mã mời / share
  ownerId   String
  owner     User           @relation("LeagueOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members   LeagueMember[]
  createdAt DateTime       @default(now())

  @@index([ownerId])
}

model LeagueMember {
  id        String   @id @default(cuid())
  leagueId  String
  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([leagueId, userId])
  @@index([userId])
}

// ---------- Pool dự đoán đội vô địch (parimutuel) ----------

model ChampionBet {
  id        String    @id @default(cuid())
  userId    String    @unique // 1 dự đoán / người (được nạp thêm vào cùng đội)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team      @relation(fields: [teamId], references: [id])
  stake     Int
  payout    Int?
  status    BetStatus @default(PENDING)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([teamId])
}
